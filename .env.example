# =============================================================================
# VoximplantBuild - Collections Dialer Configuration
# =============================================================================

# ---- Core ----
NODE_ENV=development
PORT=5000
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=8h

# ---- Database (PostgreSQL / Neon) ----
DATABASE_URL=postgresql://user:password@localhost:5432/voximplant_collections?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/voximplant_collections?schema=public

# ---- Voximplant Platform ----
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY_ID=
VOXIMPLANT_API_KEY_PATH=./vox_ci_credentials.json
VOXIMPLANT_APPLICATION_ID=
VOXIMPLANT_APPLICATION_NAME=
VOXIMPLANT_ACCOUNT_NAME=

# ---- Voximplant VoxEngine CI ----
VOX_CI_CREDENTIALS=./vox_ci_credentials.json
VOX_CI_ROOT_PATH=./voxfiles

# ---- Voximplant Phone Numbers ----
VOXIMPLANT_DEFAULT_CALLER_ID=
VOXIMPLANT_SIP_DOMAIN=
VOXIMPLANT_WEBHOOK_SECRET=change-me-to-a-random-string

# ---- AI Voice (OpenAI Realtime API) ----
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=alloy

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=VoximplantBuild

# ---- Dialer Settings ----
DIALER_MODE=preview
DIALER_POLL_INTERVAL_MS=3000
MAX_ABANDON_RATE=0.03
DEFAULT_MAX_ATTEMPTS_PER_LEAD=3
DEFAULT_RETRY_DELAY_SECONDS=3600

# ---- AMD (Answering Machine Detection) ----
AMD_ENABLED=true
AMD_INITIAL_SILENCE_MS=4500
AMD_GREETING_MS=1500
AMD_AFTER_GREETING_MS=800

# ---- Compliance ----
TCPA_WINDOW_START_HOUR=8
TCPA_WINDOW_END_HOUR=21
TCPA_DEFAULT_TIMEZONE=America/Chicago
REGF_MAX_CALLS_PER_DEBT=7
REGF_WINDOW_DAYS=7

# ---- CRM Integration (Optional) ----
CRM_BASE_URL=
CRM_API_KEY=
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=

# ---- Recording & Transcription Storage ----
RECORDING_STORAGE_URL=
TRANSCRIPT_STORAGE_URL=
