generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Users & Authentication
// =============================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("agent") // agent, supervisor, admin
  status       String   @default("offline") // available, busy, on_call, wrap_up, offline, break
  extension    String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  calls               Call[]              @relation("AgentCalls")
  campaignsCreated    Campaign[]          @relation("CampaignCreator")
  reservedContacts    CampaignContact[]   @relation("ContactReserver")
  callbacks           Callback[]
  dncEntries          DNCEntry[]          @relation("DNCAddedBy")
  complianceLogs      ComplianceLog[]     @relation("ComplianceAgent")

  @@index([role, status])
  @@index([email])
}

// =============================================================================
// Campaigns
// =============================================================================

model Campaign {
  id                  String    @id @default(uuid())
  name                String
  description         String?
  status              String    @default("draft") // draft, active, paused, completed, archived
  dialMode            String    @default("preview") // manual, preview, progressive, predictive, ai
  timezone            String    @default("America/Chicago")

  // Dialer configuration
  maxConcurrentCalls  Int       @default(10)
  dialRatio           Float     @default(1.2)
  maxAttemptsPerLead  Int       @default(3)
  retryDelaySeconds   Int       @default(3600)

  // AI configuration (when dialMode = 'ai')
  aiAgentPrompt       String?   @db.Text
  aiVoice             String?
  aiTransferEnabled   Boolean   @default(true)

  // Caller ID strategy
  callerIdStrategy    String    @default("fixed") // fixed, rotation, proximity
  fixedCallerId       String?

  // Voximplant Call List integration
  voximplantListId     Int?
  voximplantListStatus String?   // processing, stopped, completed

  // Timing
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  createdById         String
  createdBy           User       @relation("CampaignCreator", fields: [createdById], references: [id])
  contacts            CampaignContact[]
  lists               CampaignList[]
  attempts            CampaignAttempt[]
  calls               Call[]
  didGroups           CampaignDIDGroup[]

  @@index([status])
  @@index([createdById])
}

model CampaignList {
  id            String   @id @default(uuid())
  name          String
  campaignId    String
  totalContacts Int      @default(0)
  createdAt     DateTime @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contacts CampaignContact[]

  @@index([campaignId])
}

model CampaignContact {
  id              String    @id @default(uuid())
  campaignId      String
  listId          String?
  phone           String
  firstName       String?
  lastName        String?
  accountNumber   String?
  debtAmount      Float?
  timezone        String?
  status          String    @default("pending") // pending, reserved, dialing, completed, failed, skipped
  priority        Int       @default(0)
  attempts        Int       @default(0)
  lastAttemptAt   DateTime?
  nextAttemptAfter DateTime @default(now())
  reservedById    String?
  reservedAt      DateTime?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  list            CampaignList?    @relation(fields: [listId], references: [id])
  reservedBy      User?            @relation("ContactReserver", fields: [reservedById], references: [id])
  campaignAttempts CampaignAttempt[]
  calls           Call[]           @relation("ContactCalls")
  callbacks       Callback[]
  regfTrackers    RegFTracker[]
  paymentArrangements PaymentArrangement[]

  @@index([campaignId, status])
  @@index([phone])
  @@index([accountNumber])
  @@index([nextAttemptAfter])
}

model CampaignAttempt {
  id          String   @id @default(uuid())
  campaignId  String
  contactId   String
  callId      String?
  outcome     String   // answered, no_answer, busy, voicemail, failed, machine, dnc_blocked, tcpa_blocked, regf_blocked
  duration    Int      @default(0)
  createdAt   DateTime @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id])
  contact  CampaignContact  @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([contactId])
}

// =============================================================================
// Calls
// =============================================================================

model Call {
  id              String    @id @default(uuid())
  direction       String    // inbound, outbound
  status          String    @default("initiated") // initiated, ringing, in_progress, completed, failed, no_answer
  callMode        String    @default("agent") // agent, ai
  fromNumber      String
  toNumber        String
  providerCallId  String?
  duration        Int?
  answeredAt      DateTime?
  endedAt         DateTime?
  hangupReason    String?
  amdResult       String?   // human, machine, unknown
  dispositionCode String?
  notes           String?   @db.Text
  transferReason  String?

  // AI call data
  aiSummary       String?   @db.Text
  aiOutcome       String?   // payment_promised, callback_requested, refused, escalated, no_contact
  aiSentiment     String?   // positive, neutral, negative, hostile

  // Relations
  agentId         String?
  campaignId      String?
  contactId       String?
  agent           User?             @relation("AgentCalls", fields: [agentId], references: [id])
  campaign        Campaign?         @relation(fields: [campaignId], references: [id])
  contact         CampaignContact?  @relation("ContactCalls", fields: [contactId], references: [id])
  events          CallEvent[]
  recordings      CallRecording[]
  transcripts     CallTranscript[]
  callbacks       Callback[]
  paymentArrangements PaymentArrangement[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([agentId])
  @@index([campaignId])
  @@index([contactId])
  @@index([direction, createdAt])
}

model CallEvent {
  id        String   @id @default(uuid())
  callId    String
  event     String
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt])
}

model CallRecording {
  id        String   @id @default(uuid())
  callId    String
  url       String
  duration  Int      @default(0)
  format    String   @default("mp3")
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
}

model CallTranscript {
  id        String   @id @default(uuid())
  callId    String
  content   String   @db.Text
  provider  String   @default("voximplant")
  createdAt DateTime @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
}

// =============================================================================
// Callbacks
// =============================================================================

model Callback {
  id          String    @id @default(uuid())
  callId      String?
  contactId   String
  agentId     String
  phone       String
  scheduledAt DateTime
  completedAt DateTime?
  status      String    @default("pending") // pending, completed, missed, cancelled
  createdAt   DateTime  @default(now())

  call    Call?            @relation(fields: [callId], references: [id])
  contact CampaignContact  @relation(fields: [contactId], references: [id])
  agent   User             @relation(fields: [agentId], references: [id])

  @@index([agentId, scheduledAt])
  @@index([status])
}

// =============================================================================
// Phone Numbers & DID Management
// =============================================================================

model PhoneNumber {
  id            String   @id @default(uuid())
  number        String   @unique
  areaCode      String?
  state         String?
  provider      String   @default("voximplant")
  voximplantId  String?  // Voximplant phone number ID
  isActive      Boolean  @default(true)
  healthScore   Int      @default(100) // 0-100, decreases with spam flags
  dailyCallCount Int     @default(0)
  dailyCallLimit Int     @default(100)
  lastUsedAt    DateTime?
  cooldownUntil DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  didGroupLinks DIDGroupNumber[]

  @@index([areaCode])
  @@index([isActive, healthScore])
}

model DIDGroup {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  numbers   DIDGroupNumber[]
  campaigns CampaignDIDGroup[]
}

model DIDGroupNumber {
  id        String @id @default(uuid())
  groupId   String
  numberId  String

  group  DIDGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  number PhoneNumber @relation(fields: [numberId], references: [id], onDelete: Cascade)

  @@unique([groupId, numberId])
}

model CampaignDIDGroup {
  id         String @id @default(uuid())
  campaignId String
  groupId    String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  group    DIDGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([campaignId, groupId])
}

// =============================================================================
// Compliance
// =============================================================================

model DNCEntry {
  id        String   @id @default(uuid())
  phone     String   @unique
  reason    String?
  source    String   @default("manual") // manual, consumer_request, national_registry
  addedById String?
  addedBy   User?    @relation("DNCAddedBy", fields: [addedById], references: [id])
  createdAt DateTime @default(now())

  @@index([phone])
}

// Reg F: Track call frequency per debt (7 calls per 7-day window)
model RegFTracker {
  id         String   @id @default(uuid())
  contactId  String
  callId     String
  calledAt   DateTime @default(now())

  contact CampaignContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, calledAt])
}

// Audit trail for all compliance checks
model ComplianceLog {
  id         String   @id @default(uuid())
  checkType  String   // dnc, tcpa, reg_f, consent
  result     String   // allowed, blocked
  phone      String?
  contactId  String?
  agentId    String?
  details    Json     @default("{}")
  createdAt  DateTime @default(now())

  agent User? @relation("ComplianceAgent", fields: [agentId], references: [id])

  @@index([checkType, createdAt])
  @@index([phone])
}

// =============================================================================
// AI & Payment Tracking (new — not in EliteDial)
// =============================================================================

model PaymentArrangement {
  id           String    @id @default(uuid())
  callId       String
  contactId    String
  amount       Float?
  promisedDate DateTime?
  status       String    @default("promised") // promised, confirmed, broken, completed
  confirmedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  call    Call             @relation(fields: [callId], references: [id])
  contact CampaignContact  @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([status])
}

// =============================================================================
// Voicemails
// =============================================================================

model Voicemail {
  id            String    @id @default(uuid())
  fromNumber    String
  toNumber      String
  recordingUrl  String?
  transcription String?   @db.Text
  duration      Int       @default(0)
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([isRead, createdAt])
}

// =============================================================================
// System Configuration
// =============================================================================

model DispositionCode {
  id               String  @id @default(uuid())
  code             String  @unique
  label            String
  category         String? // positive, negative, neutral, callback
  requiresCallback Boolean @default(false)
  isActive         Boolean @default(true)
  sortOrder        Int     @default(0)
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
